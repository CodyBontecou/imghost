default_platform(:ios)

APP_ID = "com.codybontecou.imghost"
APPLE_ID = "bontecouc@gmail.com"
TEAM_ID = "67KC823C9A"

platform :ios do
  desc "Show current app info on App Store Connect"
  lane :info do
    deliver(
      app_identifier: APP_ID,
      username: APPLE_ID,
      team_id: TEAM_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload metadata only"
  lane :upload_metadata do
    deliver(
      app_identifier: APP_ID,
      username: APPLE_ID,
      team_id: TEAM_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload screenshots only"
  lane :upload_screenshots do
    deliver(
      app_identifier: APP_ID,
      username: APPLE_ID,
      team_id: TEAM_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload metadata + screenshots"
  lane :upload_all do
    deliver(
      app_identifier: APP_ID,
      username: APPLE_ID,
      team_id: TEAM_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Submit for review"
  lane :submit do
    deliver(
      app_identifier: APP_ID,
      username: APPLE_ID,
      team_id: TEAM_ID,
      app_version: "1.0",
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      platform: "ios",
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
