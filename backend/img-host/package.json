{
  "name": "img-host",
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "wrangler dev --ip 0.0.0.0",
    "deploy": "wrangler deploy",
    "db:init": "./scripts/init-db.sh",
    "db:migrate": "wrangler d1 execute imghost --remote --file=./migrations/0001_initial_schema.sql",
    "db:migrate:local": "wrangler d1 execute imghost --local --file=./migrations/0001_initial_schema.sql",
    "db:migrate:auth": "wrangler d1 execute imghost --remote --file=./migrations/0002_auth_enhancements.sql",
    "db:migrate:auth:local": "wrangler d1 execute imghost --local --file=./migrations/0002_auth_enhancements.sql",
    "db:migrate:export": "wrangler d1 execute imghost --remote --file=./migrations/0003_export_jobs.sql",
    "db:migrate:export:local": "wrangler d1 execute imghost --local --file=./migrations/0003_export_jobs.sql",
    "db:migrate:rate-limiting": "wrangler d1 execute imghost --remote --file=./migrations/0004_rate_limiting.sql",
    "db:migrate:rate-limiting:local": "wrangler d1 execute imghost --local --file=./migrations/0004_rate_limiting.sql",
    "db:migrate:analytics": "wrangler d1 execute imghost --remote --file=./migrations/0005_analytics_tables.sql",
    "db:migrate:analytics:local": "wrangler d1 execute imghost --local --file=./migrations/0005_analytics_tables.sql",
    "db:query": "wrangler d1 execute imghost --command",
    "db:query:local": "wrangler d1 execute imghost --local --command",
    "db:tables": "wrangler d1 execute imghost --command=\"SELECT name FROM sqlite_master WHERE type='table';\"",
    "db:tables:local": "wrangler d1 execute imghost --local --command=\"SELECT name FROM sqlite_master WHERE type='table';\"",
    "db:migrate:free-tier": "wrangler d1 execute imghost --remote --file=./migrations/0010_free_tier.sql",
    "db:migrate:free-tier:local": "wrangler d1 execute imghost --local --file=./migrations/0010_free_tier.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4",
    "wrangler": "^3.24.0"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  }
}
